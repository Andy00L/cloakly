# cloakly environment (example). Copy to .env.local and fill in real values.
# .env.local is gitignored; never commit real keys.

# Ethereum Sepolia JSON-RPC endpoint, used server-side only by the /api/rpc proxy.
# The provider key stays server-only (no NEXT_PUBLIC_ prefix) and is never shipped
# to the browser. Get one at https://infura.io (Ethereum > Sepolia) or https://alchemy.com.
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY_HERE"

# Optional. Ethereum mainnet JSON-RPC, used server-side only for READ-ONLY registry
# browsing (no transacting on mainnet). If unset, a public keyless endpoint is used, so
# mainnet browsing works with no extra configuration. Set this to your own endpoint for
# better reliability.
# MAINNET_RPC_URL="https://mainnet.infura.io/v3/YOUR_KEY_HERE"
