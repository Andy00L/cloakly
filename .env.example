# cloakly environment (example). Copy to .env.local and fill in real values.
# .env.local is gitignored; never commit real keys.

# Ethereum Sepolia JSON-RPC endpoint, used server-side only by the /api/rpc proxy.
# The provider key stays server-only (no NEXT_PUBLIC_ prefix) and is never shipped
# to the browser. Get one at https://infura.io (Ethereum > Sepolia) or https://alchemy.com.
SEPOLIA_RPC_URL="https://sepolia.infura.io/v3/YOUR_KEY_HERE"
